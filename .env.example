# claudebot — environment configuration
# Copy to .env and fill in your values

# ── Anthropic (claude-daemon) ──────────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key-here
# Claude model to use (default: claude-opus-4-6)
CLAUDE_MODEL=claude-opus-4-6

# ── OpenAI (codex-daemon) ─────────────────────────────────────────────────
OPENAI_API_KEY=your-openai-api-key-here
# Codex model to use (default: o3)
CODEX_MODEL=o3

# ── Runtime paths ─────────────────────────────────────────────────────────
# Directory for Unix sockets (defaults to /run/user/$UID)
# CLAUDE_SOCKET_DIR=/run/user/1000

# ── Web chat ──────────────────────────────────────────────────────────────
# Port for the web chat UI (default: 5003)
# WEB_CHAT_PORT=5003

# ── Telegram bot (optional) ───────────────────────────────────────────────
# TELEGRAM_BOT_TOKEN=your-telegram-bot-token
# TELEGRAM_CHAT_ID=your-telegram-chat-id
